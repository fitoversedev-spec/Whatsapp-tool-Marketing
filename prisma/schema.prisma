// Prisma schema for WhatsApp Tool
// Run: npx prisma db push (or migrate dev)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite did not support native enums, so we use String fields.
// Allowed values (validated at the API layer via Zod):
//   role: "admin" | "sales"
//   user.approvalStatus: "pending" | "approved" | "rejected"
//   template.status: "draft" | "pending_admin" | "submitted" | "approved" | "rejected" | "paused"
//   broadcast.status: "draft" | "running" | "completed" | "failed"
//   conversation.status: "open" | "closed"
//   message.direction: "inbound" | "outbound"
//   message.type: "text" | "template" | "image" | "document" | "video" | "audio"
//   message.status: "queued" | "sent" | "delivered" | "read" | "failed"

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  name            String
  role            String
  approvalStatus  String    @default("pending") @map("approval_status")
  rejectionReason String?   @map("rejection_reason")
  isActive        Boolean   @default(true) @map("is_active")
  deletedAt       DateTime? @map("deleted_at")
  // Preferred dimension unit for the app's forms + inline labels.
  // Values: "ft" (default, Indian market) | "m" (meters).
  // PDF/exported outputs always show both units regardless (Option C).
  preferredUnit   String    @default("ft") @map("preferred_unit")
  createdAt       DateTime  @default(now()) @map("created_at")

  draftedTemplates     Template[]             @relation("DraftedTemplates")
  approvedTemplates    Template[]             @relation("ApprovedTemplates")
  assignedConvos       Conversation[]         @relation("AssignedConversations")
  sentMessages         Message[]
  broadcasts           Broadcast[]
  authoredNotes        ConversationNote[]
  reminders            Reminder[]
  pipelineStageChanges PipelineStageHistory[]
  uploadedMedia        Media[]
  quotations           Quotation[]
  courtImages          CourtImage[]
  portfolioProjects    PortfolioProject[]
  products             Product[]

  @@map("users")
}

model Template {
  id               String    @id @default(uuid())
  name             String
  language         String
  category         String
  header           String?
  body             String
  footer           String?
  buttons          String?
  status           String    @default("draft")
  metaTemplateId   String?   @unique @map("meta_template_id")
  rejectionReason  String?   @map("rejection_reason")
  draftedByUserId  String    @map("drafted_by_user_id")
  approvedByUserId String?   @map("approved_by_user_id")
  submittedAt      DateTime? @map("submitted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  // Soft delete — when set, template is hidden from default list views
  // and excluded from the Broadcasts template picker. The Meta-side
  // template is NOT deleted; admin can restore from the "Show deleted"
  // filter on the Templates page.
  deletedAt        DateTime? @map("deleted_at")

  draftedBy  User        @relation("DraftedTemplates", fields: [draftedByUserId], references: [id])
  approvedBy User?       @relation("ApprovedTemplates", fields: [approvedByUserId], references: [id])
  broadcasts Broadcast[]
  messages   Message[]

  @@index([status])
  @@index([deletedAt])
  @@map("templates")
}

model Conversation {
  id                String    @id @default(uuid())
  contactPhone      String    @unique @map("contact_phone")
  contactName       String?   @map("contact_name")
  assignedToUserId  String?   @map("assigned_to_user_id")
  originBroadcastId String?   @map("origin_broadcast_id")
  status            String    @default("open")
  lastInboundAt     DateTime? @map("last_inbound_at")
  lastOutboundAt    DateTime? @map("last_outbound_at")
  unreadCount       Int       @default(0) @map("unread_count")
  createdAt         DateTime  @default(now()) @map("created_at")

  // Pipeline / lead funnel fields. All nullable to keep migration zero-risk for
  // existing rows. pipelineStage default "new" applies to fresh inserts only;
  // existing rows get null and surface in the "Unsorted" column until a sales
  // user drags them to a stage.
  pipelineStage   String?   @default("new") @map("pipeline_stage")
  stageChangedAt  DateTime? @map("stage_changed_at")
  dealValue       Decimal?  @map("deal_value") @db.Decimal(12, 2)
  expectedCloseAt DateTime? @map("expected_close_at")
  lostReason      String?   @map("lost_reason")

  assignedTo      User?                  @relation("AssignedConversations", fields: [assignedToUserId], references: [id])
  originBroadcast Broadcast?             @relation(fields: [originBroadcastId], references: [id])
  messages        Message[]
  notes           ConversationNote[]
  reminders       Reminder[]
  stageHistory    PipelineStageHistory[]
  labels          ConversationToLabel[]
  quotations      Quotation[]
  courtImages     CourtImage[]
  autoReplyLogs   AutoReplyLog[]
  botFlow         ConversationFlow?
  botLeads        BotLead[]

  @@index([assignedToUserId])
  @@index([status])
  @@index([pipelineStage])
  // Inbox list sorts by recency; index the sort key (+ the per-sales filter) so
  // it stays fast at thousands of conversations instead of a full sort.
  @@index([assignedToUserId, lastInboundAt])
  @@index([lastInboundAt])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  direction      String
  type           String
  body           String?
  mediaUrl       String?  @map("media_url")
  // Media metadata captured at upload/download time. Lets the UI render the
  // right preview (image/video/audio/document) without round-tripping to
  // Meta or refetching the blob. mediaMimeType drives the chooser; the
  // rest are display niceties.
  mediaMimeType  String?  @map("media_mime_type")
  mediaFileName  String?  @map("media_file_name")
  mediaSize      Int?     @map("media_size")
  mediaWidth     Int?     @map("media_width")
  mediaHeight    Int?     @map("media_height")
  mediaDuration  Int?     @map("media_duration") // seconds for audio/video
  waMessageId    String?  @unique @map("wa_message_id")
  templateId     String?  @map("template_id")
  status         String   @default("queued")
  errorCode      String?  @map("error_code")
  errorMessage   String?  @map("error_message")
  sentByUserId   String?  @map("sent_by_user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  template     Template?    @relation(fields: [templateId], references: [id])
  sentBy       User?        @relation(fields: [sentByUserId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Contact {
  id            String   @id @default(uuid())
  phone         String   @unique @map("phone_e164")
  name          String?
  allowCampaign Boolean  @default(true) @map("allow_campaign") // consent gate — false = never broadcast
  fields        String   @default("{}") // JSON object of extra columns (location, category, etc.)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tags ContactTag[]

  @@map("contacts")
}

model Broadcast {
  id               String    @id @default(uuid())
  name             String
  sourceType       String    @default("file") @map("source_type") // "file" | "sheet" | "contacts"
  sheetId          String?   @map("sheet_id")
  sheetRange       String?   @map("sheet_range")
  fileData         String?   @map("file_data")
  templateId       String    @map("template_id")
  variableMapping  String    @map("variable_mapping")
  // status: "draft" | "scheduled" | "running" | "completed" | "failed"
  status           String    @default("draft")
  total            Int       @default(0)
  sent             Int       @default(0)
  delivered        Int       @default(0)
  read             Int       @default(0)
  failed           Int       @default(0)
  createdByUserId  String    @map("created_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  // When set, broadcast is held in "scheduled" status until the launch cron
  // (or a safety on-load check) flips it to "running". Hobby cron = up to 1hr
  // delay; we surface this in the UI.
  scheduledAt      DateTime? @map("scheduled_at")
  launchedAt       DateTime? @map("launched_at")
  completedAt      DateTime? @map("completed_at")
  // Pause control. pauseRequestedAt is set when the user clicks Pause; the
  // sender loop checks this between batches and writes pausedAt + flips
  // status to "paused" once it's actually safe to stop. Resume clears both.
  pauseRequestedAt DateTime? @map("pause_requested_at")
  pausedAt         DateTime? @map("paused_at")

  template      Template             @relation(fields: [templateId], references: [id])
  createdBy     User                 @relation(fields: [createdByUserId], references: [id])
  recipients    BroadcastRecipient[]
  conversations Conversation[]

  @@index([createdByUserId])
  @@index([status])
  @@index([scheduledAt])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id           String    @id @default(uuid())
  broadcastId  String    @map("broadcast_id")
  phoneE164    String    @map("phone_e164")
  name         String?
  variables    String
  waMessageId  String?   @unique @map("wa_message_id")
  status       String    @default("queued")
  errorCode    String?   @map("error_code")
  errorMessage String?   @map("error_message")
  sentAt       DateTime? @map("sent_at")
  deliveredAt  DateTime? @map("delivered_at")
  readAt       DateTime? @map("read_at")

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, phoneE164])
  @@index([waMessageId])
  @@map("broadcast_recipients")
}

model OptOut {
  phoneE164  String   @id @map("phone_e164")
  optedOutAt DateTime @default(now()) @map("opted_out_at")
  reason     String

  @@map("opt_outs")
}

// Key-value config storage. Holds the long-lived Meta access token
// and its expiry (seconds since epoch) for the auto-refresh cycle.
// Keys: "meta_access_token", "meta_token_expires_at",
//       "pipeline_stages" (JSON array of stage configs)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// Free-text notes attached to a conversation, visible to all users who can
// access that conversation. Pinned notes float to the top of the panel.
model ConversationNote {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  authorUserId   String    @map("author_user_id")
  body           String
  pinned         Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  editedAt       DateTime? @map("edited_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorUserId], references: [id])

  @@index([conversationId, createdAt])
  @@map("conversation_notes")
}

// Per-user follow-up reminders. May be linked to a conversation (most common)
// or standalone. The cron worker fires notifiedAt when notifying; UI also
// performs an on-load safety check for overdue reminders.
model Reminder {
  id             String    @id @default(uuid())
  conversationId String?   @map("conversation_id")
  ownerUserId    String    @map("owner_user_id")
  message        String
  dueAt          DateTime  @map("due_at")
  completedAt    DateTime? @map("completed_at")
  notifiedAt     DateTime? @map("notified_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  owner        User          @relation(fields: [ownerUserId], references: [id])

  @@index([ownerUserId, dueAt])
  @@index([dueAt, completedAt])
  @@map("reminders")
}

// Append-only audit log of pipeline stage changes. Powers the "days in stage"
// metric and cycle-time analytics.
model PipelineStageHistory {
  id              String   @id @default(uuid())
  conversationId  String   @map("conversation_id")
  fromStage       String?  @map("from_stage")
  toStage         String   @map("to_stage")
  changedByUserId String   @map("changed_by_user_id")
  changedAt       DateTime @default(now()) @map("changed_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  changedBy    User         @relation(fields: [changedByUserId], references: [id])

  @@index([conversationId, changedAt])
  @@map("pipeline_stage_history")
}

// Colored, named tags applied to contacts. Tag names are globally unique;
// color is a tailwind palette token (slate/blue/amber/...) — see lib/
// pipeline.ts STAGE_COLOR_CLASSES for the recognised set.
model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("slate")
  createdAt DateTime @default(now()) @map("created_at")

  contacts ContactTag[]

  @@map("tags")
}

model ContactTag {
  contactId String   @map("contact_id")
  tagId     String   @map("tag_id")
  taggedAt  DateTime @default(now()) @map("tagged_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
  @@map("contact_tags")
}

// Operational state labels applied to conversations (distinct from
// pipeline stages which model the sales funnel). Examples: "Needs follow-up",
// "Waiting customer", "Action required".
model ConversationLabel {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("slate")
  createdAt DateTime @default(now()) @map("created_at")

  conversations ConversationToLabel[]

  @@map("conversation_labels")
}

model ConversationToLabel {
  conversationId String   @map("conversation_id")
  labelId        String   @map("label_id")
  labeledAt      DateTime @default(now()) @map("labeled_at")

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  label        ConversationLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([conversationId, labelId])
  @@index([labelId])
  @@map("conversation_to_labels")
}

// Sales quotations. Each row stores a snapshot of line items + totals at
// the time of creation, so changing the rate sheet later doesn't retro-
// actively alter prices customers have already seen. PDF is rendered on
// demand (and cached at pdfUrl after first send).
//
// Numbering is sequential per calendar year, format "FIT-QT-YYYY-NNN".
// Status flow: draft → sent → (viewed | accepted | expired).
model Quotation {
  id              String    @id @default(uuid())
  number          String    @unique
  customerName    String    @map("customer_name")
  sport           String    @default("football")
  lengthFt        Int       @map("length_ft")
  widthFt         Int       @map("width_ft")
  // JSON snapshot — array of { id, name, description, areaSqFt, ratePerSqFt,
  //   gstPercent, total, included }. Description is user-editable per quote.
  lineItems       String    @map("line_items")
  subtotal        Decimal   @db.Decimal(12, 2)
  gstAmount       Decimal   @map("gst_amount") @db.Decimal(12, 2)
  grandTotal      Decimal   @map("grand_total") @db.Decimal(12, 2)
  notes           String?
  // Optional customer-facing caption. When set, /send delivers it as a
  // text message immediately before the PDF so WhatsApp displays it as
  // a clear intro instead of hiding it under the document thumbnail.
  caption         String?
  pdfUrl          String?   @map("pdf_url")
  status          String    @default("draft")
  quoteDate       DateTime  @map("quote_date")
  validityDays    Int       @default(30) @map("validity_days")
  sentAt          DateTime? @map("sent_at")
  conversationId  String?   @map("conversation_id")
  contactPhone    String?   @map("contact_phone")
  createdByUserId String    @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  createdBy    User          @relation(fields: [createdByUserId], references: [id])

  @@index([status])
  @@index([conversationId])
  @@index([contactPhone])
  @@index([createdAt])
  @@map("quotations")
}

// Centralized media library. Every file upload goes through here so we can
// list, audit, and de-dup. Existing template/message media URLs continue to
// work without a Media row — the library only shows what was uploaded via
// the new flows.
model Media {
  id               String   @id @default(uuid())
  url              String
  mimeType         String   @map("mime_type")
  fileName         String   @map("file_name")
  size             Int
  width            Int?
  height           Int?
  duration         Int? // seconds for audio/video
  // "image" | "video" | "audio" | "document" | "other" — denormalized from
  // mimeType for cheap filtering in the library UI.
  category         String   @default("other")
  uploadedByUserId String   @map("uploaded_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  uploadedBy User @relation(fields: [uploadedByUserId], references: [id])

  @@index([category])
  @@index([uploadedByUserId])
  @@map("media")
}

// Audit log for auto-reply rule firings. Every time a rule fires we
// record which rule + which contact + when so the dispatcher can honour
// per-contact cooldowns (don't spam the customer with the same greeting
// twice in 24 hours) and admin has visibility into what the bot sent.
model AutoReplyLog {
  id             String   @id @default(uuid())
  ruleId         String   @map("rule_id")
  conversationId String   @map("conversation_id")
  contactPhone   String   @map("contact_phone")
  triggeredBy    String?  @map("triggered_by")
  waMessageId    String?  @map("wa_message_id")
  firedAt        DateTime @default(now()) @map("fired_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([ruleId, contactPhone, firedAt])
  @@index([conversationId])
  @@map("auto_reply_logs")
}

// Chatbot state — a lightweight state machine per conversation. Drives
// the multi-turn flow (Phase 0 menu → branch → data collection → end).
// One row per conversation; deleted or ended after completion. 4-hour
// timeout after last update — next inbound restarts from Phase 0.
model ConversationFlow {
  id             String    @id @default(uuid())
  conversationId String    @unique @map("conversation_id")
  // "turnkey_new" | "turnkey_maintenance" | "consultation" | "product" | null (menu shown, path not picked yet)
  path           String?
  // Step identifier from the code-side step registry (e.g. "menu",
  // "p1a_name", "p1b_service", "p3_datetime", "done").
  currentStep    String    @map("current_step")
  // JSON of collected fields: {name, phone, location, landSize, sport,
  // maintenanceType, preferredDateTime, ...}. Nullable until first field
  // captured; overwritten on each step advance.
  collectedData  String    @default("{}") @map("collected_data")
  startedAt      DateTime  @default(now()) @map("started_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  endedAt        DateTime? @map("ended_at")
  // "completed" | "off_script" | "timeout" | null (still active)
  endReason      String?   @map("end_reason")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([currentStep])
  @@index([updatedAt])
  @@map("conversation_flows")
}

// Captured leads from the chatbot. One row per completed (or partially
// completed off-script) flow. Sales sees these in a daily data-sheet at
// /leads and moves them into the pipeline manually.
model BotLead {
  id                String    @id @default(uuid())
  conversationId    String    @map("conversation_id")
  contactPhone      String    @map("contact_phone")
  contactName       String?   @map("contact_name")
  // "turnkey_new" | "turnkey_maintenance" | "consultation" | "product"
  path              String
  location          String?
  // For turnkey_new: land size (ft). For turnkey_maintenance: turf size.
  sizeFt            Decimal?  @map("size_ft") @db.Decimal(10, 2)
  // For turnkey_new
  sport             String?
  // For turnkey_maintenance
  maintenanceType   String?   @map("maintenance_type")
  // For product
  productCategory   String?   @map("product_category")
  // For consultation — ISO datetime string of preferred callback slot
  preferredDateTime DateTime? @map("preferred_datetime")
  // "new" | "in_progress" | "contacted" | "converted" | "lost"
  status            String    @default("new")
  assignedToUserId  String?   @map("assigned_to_user_id")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([path])
  @@index([assignedToUserId])
  @@index([conversationId])
  @@map("bot_leads")
}

// Court layout designs — visual 2D editable canvas that exports a PNG sent
// to the customer over WhatsApp. The full editable layout (sports, plot,
// element positions/sizes/rotations/colors, annotations) is stored as JSON
// so sales can re-open the design, tweak it, and re-render. The same
// schema feeds a future 3D renderer without remodeling.
//
// Numbering: "FIT-CIM-YYYY-NNN" sequential per calendar year.
// Status flow: draft -> sent.
model CourtImage {
  id              String    @id @default(uuid())
  number          String    @unique
  customerName    String    @map("customer_name")
  // JSON snapshot of the CourtLayout — see src/lib/court-image/schema.ts.
  // Shape: { plot, sports, elements: [...], style }.
  layout          String
  // PNG exported from the canvas + uploaded to Vercel Blob.
  // Null until the user saves/sends; re-saved if they edit.
  // imageUrl is the "primary" — set to whichever format was sent first,
  // for inbox mirror compatibility. Format-specific URLs below track all
  // the variants the user generated so a single design can be re-sent as
  // 2D plan + 3D snapshot + 3D orbit video in any combination.
  imageUrl        String?   @map("image_url")
  image2dUrl      String?   @map("image_2d_url")
  image3dUrl      String?   @map("image_3d_url")
  video3dUrl      String?   @map("video_3d_url")
  caption         String?
  status          String    @default("draft")
  conversationId  String?   @map("conversation_id")
  contactPhone    String?   @map("contact_phone")
  createdByUserId String    @map("created_by_user_id")
  sentAt          DateTime? @map("sent_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  createdBy    User          @relation(fields: [createdByUserId], references: [id])

  @@index([status])
  @@index([conversationId])
  @@index([contactPhone])
  @@index([createdAt])
  @@map("court_images")
}

// Past Fitoverse builds. When a customer asks "what football turfs have
// you done?", sales pulls a sport-filtered slice of these into a
// catalogue PDF + hero photos and sends it on WhatsApp.
//
// `featured` controls inclusion in the catalogue PDF (so admin can curate
// which builds best represent the brand) without deleting older rows.
// `archived` hides from the default listing without breaking external
// references (the sport catalogue PDF that's already been sent to a
// customer keeps working even if the project is archived later).
model PortfolioProject {
  id               String    @id @default(uuid())
  customerName     String    @map("customer_name")
  location         String?
  sport            String
  completionDate   DateTime? @map("completion_date")
  plotLengthFt     Int?      @map("plot_length_ft")
  plotWidthFt      Int?      @map("plot_width_ft")
  surfaceType      String?   @map("surface_type")
  surfaceGrade     String?   @map("surface_grade")
  // Admin-only display field; never sent to customers. Used internally
  // for catalogue tier hints (entry / standard / premium).
  totalCostInr     Decimal?  @map("total_cost_inr") @db.Decimal(12, 2)
  shortDescription String?   @map("short_description")
  // JSON array of { url, caption?: string }. Hero photo is rendered
  // separately on the catalogue cover; gallery shows on the project
  // page + PDF "past projects" section.
  photos           String    @default("[]")
  heroPhotoUrl     String?   @map("hero_photo_url")
  videoUrl         String?   @map("video_url")
  // Free-form JSON for sport-specific specs (e.g. turf brand,
  // a-side preset, pitch length) — surfaces in the catalogue PDF.
  specs            String    @default("{}")
  // Comma-separated for simple search
  tags             String    @default("")
  featured         Boolean   @default(false)
  archived         Boolean   @default(false)
  createdByUserId  String    @map("created_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  createdBy User @relation(fields: [createdByUserId], references: [id])

  @@index([sport])
  @@index([featured])
  @@index([archived])
  @@map("portfolio_projects")
}

// ─────────────────────────────────────────────────────────────────────
//  Internal product catalogue (replaces the MVPv2 dependency).
//
//  Sales uploads floorings, materials, and sports equipment here. The
//  court designer + chatbot read from these tables instead of the
//  sibling MVPv2 web tool. TDS PDFs attach per sport (and optionally to
//  a specific product).
// ─────────────────────────────────────────────────────────────────────

model Product {
  id          String @id @default(uuid())
  name        String
  // "flooring" | "material" | "equipment"
  //   flooring  — turf / acrylic / PPE tile / PVC surfaces
  //   material  — infill, adhesives, sub-base consumables
  //   equipment — goal posts, nets, machines, shot clocks, etc.
  type        String
  description String @default("")
  // JSON array of sport keys this product applies to, e.g.
  // ["football","multisport"]. Court designer + chatbot filter by sport.
  sports      String @default("[]")
  // Optional sub-category within a type — flooring → "turf" / "acrylic"
  // / "ppe_tile" / "pvc"; equipment → "goal" / "net" / "machine".
  category    String?
  // Hero photo shown in listings. Gallery + video live in ProductMedia.
  heroImageUrl String? @map("hero_image_url")
  videoUrl     String? @map("video_url")
  // Free-form JSON specs { key: value } shown in the product detail +
  // combined PDF.
  specs        String  @default("{}")
  // Optional indicative price + unit for the combined PDF / quote line.
  priceInr     Decimal? @map("price_inr") @db.Decimal(12, 2)
  unit         String?
  // For flooring: the base work it sits on ("concrete" | "asphalt" |
  // null). Informational — surfaces in the design + PDF.
  baseWork     String?  @map("base_work")
  featured     Boolean  @default(false)
  archived     Boolean  @default(false)
  createdByUserId String @map("created_by_user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdBy User           @relation(fields: [createdByUserId], references: [id])
  media     ProductMedia[]
  tdsFiles  TdsFile[]

  @@index([type])
  @@index([featured])
  @@index([archived])
  @@map("products")
}

model ProductMedia {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  url       String
  // "image" | "video"
  kind      String   @default("image")
  caption   String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_media")
}

model TdsFile {
  id               String   @id @default(uuid())
  sport            String
  name             String
  url              String
  // Optional link to a specific product (a TDS can be sport-level or
  // product-specific).
  productId        String?  @map("product_id")
  uploadedByUserId String?  @map("uploaded_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([sport])
  @@index([productId])
  @@map("tds_files")
}
