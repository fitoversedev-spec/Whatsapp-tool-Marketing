// Prisma schema for WhatsApp Tool
// Run: npx prisma db push (or migrate dev)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite did not support native enums, so we use String fields.
// Allowed values (validated at the API layer via Zod):
//   role: "admin" | "sales" | "manager" | "management"
//     (manager/management are granted only via the admin-controlled /users
//     page — public self-signup keeps offering just admin/sales.)
//   user.approvalStatus: "pending" | "approved" | "rejected"
//   template.status: "draft" | "pending_admin" | "submitted" | "approved" | "rejected" | "paused"
//   broadcast.status: "draft" | "running" | "completed" | "failed"
//   conversation.status: "open" | "closed"
//   message.direction: "inbound" | "outbound"
//   message.type: "text" | "template" | "image" | "document" | "video" | "audio"
//   message.status: "queued" | "sent" | "delivered" | "read" | "failed"

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  name            String
  role            String
  approvalStatus  String    @default("pending") @map("approval_status")
  rejectionReason String?   @map("rejection_reason")
  isActive        Boolean   @default(true) @map("is_active")
  deletedAt       DateTime? @map("deleted_at")
  // Preferred dimension unit for the app's forms + inline labels.
  // Values: "ft" (default, Indian market) | "m" (meters).
  // PDF/exported outputs always show both units regardless (Option C).
  preferredUnit   String    @default("ft") @map("preferred_unit")
  officeId        String?   @map("office_id")
  // Staff sender identification for WhatsApp bot commands (spec §10) — the
  // inbound webhook matches msg.from against this to tell "a rep texting
  // the business number" apart from a customer. Nullable/unique: existing
  // users get it filled in by an admin once they opt into bot commands.
  phone           String?   @unique @map("phone")
  createdAt       DateTime  @default(now()) @map("created_at")

  office               Office?                @relation(fields: [officeId], references: [id])
  draftedTemplates     Template[]             @relation("DraftedTemplates")
  approvedTemplates    Template[]             @relation("ApprovedTemplates")
  assignedConvos       Conversation[]         @relation("AssignedConversations")
  sentMessages         Message[]
  broadcasts           Broadcast[]
  authoredNotes        ConversationNote[]
  reminders            Reminder[]
  pipelineStageChanges PipelineStageHistory[]
  uploadedMedia        Media[]
  quotations           Quotation[]
  courtImages          CourtImage[]
  portfolioProjects    PortfolioProject[]
  products             Product[]
  ownedAccounts        Account[]              @relation("AccountOwner")
  ownedLeads           Lead[]                 @relation("LeadOwner")
  ownedDeals           Deal[]                 @relation("DealOwner")
  dealStageChanges     DealStageHistory[]
  activities           Activity[]             @relation("ActivityOwner")
  accountContactNotes  AccountContactNote[]
  accountContactAttachments AccountContactAttachment[]
  importBatches        ImportBatch[]
  pendingStaffAction   PendingStaffAction?
  auditLogs            AuditLog[]
  targetsSet           Target[]
  decisionsLogged      DecisionLog[]

  @@map("users")
}

// Fitoverse's real offices (Salem/Chennai/Bangalore) — seeded, not user-created.
// Nullable everywhere it's referenced (User.officeId, Deal.officeId): existing
// rows get null and an admin assigns an office manually, no data to infer it from.
model Office {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  city      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  users User[]
  deals Deal[]

  @@map("offices")
}

model Template {
  id               String    @id @default(uuid())
  name             String
  language         String
  category         String
  header           String?
  body             String
  footer           String?
  buttons          String?
  status           String    @default("draft")
  metaTemplateId   String?   @unique @map("meta_template_id")
  rejectionReason  String?   @map("rejection_reason")
  draftedByUserId  String    @map("drafted_by_user_id")
  approvedByUserId String?   @map("approved_by_user_id")
  submittedAt      DateTime? @map("submitted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  // Soft delete — when set, template is hidden from default list views
  // and excluded from the Broadcasts template picker. The Meta-side
  // template is NOT deleted; admin can restore from the "Show deleted"
  // filter on the Templates page.
  deletedAt        DateTime? @map("deleted_at")

  draftedBy  User        @relation("DraftedTemplates", fields: [draftedByUserId], references: [id])
  approvedBy User?       @relation("ApprovedTemplates", fields: [approvedByUserId], references: [id])
  broadcasts Broadcast[]
  messages   Message[]

  @@index([status])
  @@index([deletedAt])
  @@map("templates")
}

model Conversation {
  id                String    @id @default(uuid())
  contactPhone      String    @unique @map("contact_phone")
  contactName       String?   @map("contact_name")
  assignedToUserId  String?   @map("assigned_to_user_id")
  originBroadcastId String?   @map("origin_broadcast_id")
  status            String    @default("open")
  lastInboundAt     DateTime? @map("last_inbound_at")
  lastOutboundAt    DateTime? @map("last_outbound_at")
  unreadCount       Int       @default(0) @map("unread_count")
  createdAt         DateTime  @default(now()) @map("created_at")

  // Pipeline / lead funnel fields. All nullable to keep migration zero-risk for
  // existing rows. pipelineStage default "new" applies to fresh inserts only;
  // existing rows get null and surface in the "Unsorted" column until a sales
  // user drags them to a stage.
  pipelineStage   String?   @default("new") @map("pipeline_stage")
  stageChangedAt  DateTime? @map("stage_changed_at")
  dealValue       Decimal?  @map("deal_value") @db.Decimal(12, 2)
  expectedCloseAt DateTime? @map("expected_close_at")
  lostReason      String?   @map("lost_reason")

  assignedTo      User?                  @relation("AssignedConversations", fields: [assignedToUserId], references: [id])
  originBroadcast Broadcast?             @relation(fields: [originBroadcastId], references: [id])
  messages        Message[]
  notes           ConversationNote[]
  reminders       Reminder[]
  stageHistory    PipelineStageHistory[]
  labels          ConversationToLabel[]
  quotations      Quotation[]
  courtImages     CourtImage[]
  autoReplyLogs   AutoReplyLog[]
  botFlow         ConversationFlow?
  botLeads        BotLead[]
  deals           Deal[]

  @@index([assignedToUserId])
  @@index([status])
  @@index([pipelineStage])
  // Inbox list sorts by recency; index the sort key (+ the per-sales filter) so
  // it stays fast at thousands of conversations instead of a full sort.
  @@index([assignedToUserId, lastInboundAt])
  @@index([lastInboundAt])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  direction      String
  type           String
  body           String?
  mediaUrl       String?  @map("media_url")
  // Media metadata captured at upload/download time. Lets the UI render the
  // right preview (image/video/audio/document) without round-tripping to
  // Meta or refetching the blob. mediaMimeType drives the chooser; the
  // rest are display niceties.
  mediaMimeType  String?  @map("media_mime_type")
  mediaFileName  String?  @map("media_file_name")
  mediaSize      Int?     @map("media_size")
  mediaWidth     Int?     @map("media_width")
  mediaHeight    Int?     @map("media_height")
  mediaDuration  Int?     @map("media_duration") // seconds for audio/video
  waMessageId    String?  @unique @map("wa_message_id")
  templateId     String?  @map("template_id")
  status         String   @default("queued")
  errorCode      String?  @map("error_code")
  errorMessage   String?  @map("error_message")
  sentByUserId   String?  @map("sent_by_user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  template     Template?    @relation(fields: [templateId], references: [id])
  sentBy       User?        @relation(fields: [sentByUserId], references: [id])

  @@index([conversationId, createdAt])
  // Serves src/app/api/team/analytics/route.ts's per-rep "messages sent"
  // groupBy exactly: equality-filters direction, groups/filters
  // sentByUserId (not-null), range-filters createdAt — column order matches
  // that access pattern. Message is the largest table in this schema, so an
  // unindexed groupBy here is the one candidate the performance audit
  // couldn't rule out without live EXPLAIN ANALYZE access. Additive/free to
  // add regardless. See docs/DECISIONS.md.
  @@index([direction, sentByUserId, createdAt])
  @@map("messages")
}

model Contact {
  id            String   @id @default(uuid())
  phone         String   @unique @map("phone_e164")
  name          String?
  allowCampaign Boolean  @default(true) @map("allow_campaign") // consent gate — false = never broadcast
  fields        String   @default("{}") // JSON object of extra columns (location, category, etc.)
  // Set when someone clicks "Move to CRM" on this contact's conversation in
  // the Inbox. Nullable — most marketing contacts never become a CRM lead.
  // @unique makes this a true 1:1: one WhatsApp phone number maps to at
  // most one CRM person, matching how the reverse ("Sync to WhatsApp
  // Marketing") direction already treats phone as the identity key.
  accountContactId String? @unique @map("account_contact_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tags           ContactTag[]
  accountContact AccountContact? @relation(fields: [accountContactId], references: [id], onDelete: SetNull)

  @@map("contacts")
}

model Broadcast {
  id               String    @id @default(uuid())
  name             String
  sourceType       String    @default("file") @map("source_type") // "file" | "sheet" | "contacts"
  sheetId          String?   @map("sheet_id")
  sheetRange       String?   @map("sheet_range")
  fileData         String?   @map("file_data")
  templateId       String    @map("template_id")
  variableMapping  String    @map("variable_mapping")
  // status: "draft" | "scheduled" | "running" | "completed" | "failed"
  status           String    @default("draft")
  total            Int       @default(0)
  sent             Int       @default(0)
  delivered        Int       @default(0)
  read             Int       @default(0)
  failed           Int       @default(0)
  createdByUserId  String    @map("created_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  // When set, broadcast is held in "scheduled" status until the launch cron
  // (or a safety on-load check) flips it to "running". Hobby cron = up to 1hr
  // delay; we surface this in the UI.
  scheduledAt      DateTime? @map("scheduled_at")
  launchedAt       DateTime? @map("launched_at")
  completedAt      DateTime? @map("completed_at")
  // Pause control. pauseRequestedAt is set when the user clicks Pause; the
  // sender loop checks this between batches and writes pausedAt + flips
  // status to "paused" once it's actually safe to stop. Resume clears both.
  pauseRequestedAt DateTime? @map("pause_requested_at")
  pausedAt         DateTime? @map("paused_at")

  template      Template             @relation(fields: [templateId], references: [id])
  createdBy     User                 @relation(fields: [createdByUserId], references: [id])
  recipients    BroadcastRecipient[]
  conversations Conversation[]

  @@index([createdByUserId])
  @@index([status])
  @@index([scheduledAt])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id           String    @id @default(uuid())
  broadcastId  String    @map("broadcast_id")
  phoneE164    String    @map("phone_e164")
  name         String?
  variables    String
  waMessageId  String?   @unique @map("wa_message_id")
  status       String    @default("queued")
  errorCode    String?   @map("error_code")
  errorMessage String?   @map("error_message")
  sentAt       DateTime? @map("sent_at")
  deliveredAt  DateTime? @map("delivered_at")
  readAt       DateTime? @map("read_at")

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, phoneE164])
  @@index([waMessageId])
  @@map("broadcast_recipients")
}

model OptOut {
  phoneE164  String   @id @map("phone_e164")
  optedOutAt DateTime @default(now()) @map("opted_out_at")
  reason     String

  @@map("opt_outs")
}

// Key-value config storage. Holds the long-lived Meta access token
// and its expiry (seconds since epoch) for the auto-refresh cycle.
// Keys: "meta_access_token", "meta_token_expires_at",
//       "pipeline_stages" (JSON array of stage configs)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// Free-text notes attached to a conversation, visible to all users who can
// access that conversation. Pinned notes float to the top of the panel.
model ConversationNote {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  authorUserId   String    @map("author_user_id")
  body           String
  pinned         Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  editedAt       DateTime? @map("edited_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorUserId], references: [id])

  @@index([conversationId, createdAt])
  @@map("conversation_notes")
}

// Per-user follow-up reminders. May be linked to a conversation (most common)
// or standalone. The cron worker fires notifiedAt when notifying; UI also
// performs an on-load safety check for overdue reminders.
model Reminder {
  id             String    @id @default(uuid())
  conversationId String?   @map("conversation_id")
  ownerUserId    String    @map("owner_user_id")
  message        String
  dueAt          DateTime  @map("due_at")
  completedAt    DateTime? @map("completed_at")
  notifiedAt     DateTime? @map("notified_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Phase 3 additions — additive/nullable, existing completedAt/notifiedAt-
  // based logic in api/reminders/** keeps working unchanged; new dispatch
  // code (cron-runner.ts) is what actually reads/writes these.
  dealId         String?   @map("deal_id")
  // A Reminder (task/meeting/call) can now anchor to a contact directly, not
  // only a Deal — Zoho-style activities on a contact with no deal.
  accountContactId String? @map("account_contact_id")
  activityTypeId String?   @map("activity_type_id")
  // e.g. ["whatsapp","in_app"]. Empty/absent = in-app only (today's behavior).
  channels       String[]  @default([])
  // "PENDING"|"SENT"|"DONE"|"SNOOZED"|"CANCELLED" — informational alongside
  // the timestamp fields, not (yet) a replacement for them.
  status         String    @default("PENDING")
  snoozedUntil   DateTime? @map("snoozed_until")
  // RRULE string for periodic follow-ups; null = one-off (today's only mode).
  recurrenceRule String?   @map("recurrence_rule")
  meetingUrl     String?   @map("meeting_url")
  location       String?
  // Short note left when marking a reminder (meeting/call/task) complete —
  // "what actually happened", surfaced in the unified timeline in place of
  // the original location/meetingUrl once set. See docs/DECISIONS.md.
  completionNote String?   @map("completion_note")
  // Task priority — set only for CRM "Task" reminders; null for every other
  // reminder kind (scheduled call/meeting follow-ups).
  priority       String?   @map("priority") // "HIGH" | "MEDIUM" | "LOW", null for non-task reminders

  conversation Conversation?      @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  owner        User               @relation(fields: [ownerUserId], references: [id])
  deal         Deal?              @relation(fields: [dealId], references: [id], onDelete: SetNull)
  accountContact AccountContact?  @relation(fields: [accountContactId], references: [id], onDelete: SetNull)
  activityType ActivityType?      @relation(fields: [activityTypeId], references: [id])
  dispatches   ReminderDispatch[]

  @@index([ownerUserId, dueAt])
  @@index([dueAt, completedAt])
  @@index([dealId])
  @@index([accountContactId])
  @@map("reminders")
}

// Audit of what was actually dispatched, on which channel — the row is
// written BEFORE the send attempt (inside a transaction with a uniqueness
// guard) so a retried/concurrent cron sweep can never double-send the same
// reminder on the same channel (spec §9.2).
model ReminderDispatch {
  id                String   @id @default(uuid())
  reminderId        String   @map("reminder_id")
  channel           String
  sentAt            DateTime @default(now()) @map("sent_at")
  providerMessageId String?  @map("provider_message_id")
  error             String?

  reminder Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@unique([reminderId, channel])
  @@map("reminder_dispatches")
}

// One pending yes/no confirmation per staff phone number for the WhatsApp
// bot commands that need a confirm step before writing anything (spec §10:
// `remind` echoes the parsed date-time back, `stage` confirms the
// fuzzy-matched transition) — never execute on the strength of a single
// message. Cleared on confirm/cancel or once expired; a stale row is
// treated as if none exists rather than silently executed late.
model PendingStaffAction {
  id         String   @id @default(uuid())
  userId     String   @unique @map("user_id")
  // "remind" | "stage"
  kind       String
  // JSON payload specific to `kind` — e.g. {dueAt, title} for remind,
  // {dealId, dealCode, toStageId, stageName} for stage.
  payload    String
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pending_staff_actions")
}

// Append-only audit log of pipeline stage changes. Powers the "days in stage"
// metric and cycle-time analytics.
model PipelineStageHistory {
  id              String   @id @default(uuid())
  conversationId  String   @map("conversation_id")
  fromStage       String?  @map("from_stage")
  toStage         String   @map("to_stage")
  changedByUserId String   @map("changed_by_user_id")
  changedAt       DateTime @default(now()) @map("changed_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  changedBy    User         @relation(fields: [changedByUserId], references: [id])

  @@index([conversationId, changedAt])
  @@map("pipeline_stage_history")
}

// Spec §3.2/§14 ("every mutation audit-logged") + §13 (MANAGEMENT/ADMIN can
// view it). actorId nullable for system-driven writes (e.g. the reminder
// cron). diff is a free-form JSON snapshot of what changed — intentionally
// loose (no per-entity schema) since this spans every entity type in the
// app, not just the new CRM models.
model AuditLog {
  id       String   @id @default(uuid())
  actorId  String?  @map("actor_id")
  entity   String
  entityId String   @map("entity_id")
  // "CREATE" | "UPDATE" | "DELETE" | "STAGE_CHANGE" | "SEND"
  action   String
  diff     String?
  at       DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entity, entityId, at])
  @@index([actorId, at])
  @@map("audit_log")
}

// Phase 5 insight-engine companion to AuditLog: records the human decision a
// surfaced insight led to (or a standalone call), so the digest/insight feed
// can close the loop ("you acted on this"). triggeredByInsightId is the
// deterministic rule-id/key from insights.ts, nullable for decisions logged
// without an originating insight. Mirrors AuditLog's single-chokepoint
// convention (see src/lib/decisionLog.ts).
model DecisionLog {
  id                   String   @id @default(uuid())
  recordedByUserId     String   @map("recorded_by_user_id")
  decision             String
  triggeredByInsightId String?  @map("triggered_by_insight_id")
  decidedAt            DateTime @map("decided_at")
  createdAt            DateTime @default(now()) @map("created_at")

  recordedBy User @relation(fields: [recordedByUserId], references: [id])

  @@index([decidedAt])
  @@map("decision_log")
}

// Colored, named tags applied to contacts. Tag names are globally unique;
// color is a tailwind palette token (slate/blue/amber/...) — see lib/
// pipeline.ts STAGE_COLOR_CLASSES for the recognised set.
model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("slate")
  createdAt DateTime @default(now()) @map("created_at")

  contacts ContactTag[]

  @@map("tags")
}

model ContactTag {
  contactId String   @map("contact_id")
  tagId     String   @map("tag_id")
  taggedAt  DateTime @default(now()) @map("tagged_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
  @@map("contact_tags")
}

// Operational state labels applied to conversations (distinct from
// pipeline stages which model the sales funnel). Examples: "Needs follow-up",
// "Waiting customer", "Action required".
model ConversationLabel {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("slate")
  createdAt DateTime @default(now()) @map("created_at")

  conversations ConversationToLabel[]

  @@map("conversation_labels")
}

model ConversationToLabel {
  conversationId String   @map("conversation_id")
  labelId        String   @map("label_id")
  labeledAt      DateTime @default(now()) @map("labeled_at")

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  label        ConversationLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([conversationId, labelId])
  @@index([labelId])
  @@map("conversation_to_labels")
}

// Sales quotations. Each row stores a snapshot of line items + totals at
// the time of creation, so changing the rate sheet later doesn't retro-
// actively alter prices customers have already seen. PDF is rendered on
// demand (and cached at pdfUrl after first send).
//
// Numbering is sequential per calendar year, format "FIT-QT-YYYY-NNN".
// Status flow: draft → sent → (viewed | accepted | expired).
model Quotation {
  id              String    @id @default(uuid())
  number          String    @unique
  customerName    String    @map("customer_name")
  sport           String    @default("football")
  lengthFt        Int       @map("length_ft")
  widthFt         Int       @map("width_ft")
  // JSON snapshot — array of { id, name, description, areaSqFt, ratePerSqFt,
  //   gstPercent, total, included }. Description is user-editable per quote.
  lineItems       String    @map("line_items")
  subtotal        Decimal   @db.Decimal(12, 2)
  gstAmount       Decimal   @map("gst_amount") @db.Decimal(12, 2)
  grandTotal      Decimal   @map("grand_total") @db.Decimal(12, 2)
  notes           String?
  // Optional customer-facing caption. When set, /send delivers it as a
  // text message immediately before the PDF so WhatsApp displays it as
  // a clear intro instead of hiding it under the document thumbnail.
  caption         String?
  pdfUrl          String?   @map("pdf_url")
  // "draft"|"sent"|"viewed"|"accepted"|"expired" (pre-existing) plus
  // "rejected"|"superseded" (Phase 2, additive — viewed/expired are real
  // live statuses already, not replaced).
  status          String    @default("draft")
  quoteDate       DateTime  @map("quote_date")
  validityDays    Int       @default(30) @map("validity_days")
  sentAt          DateTime? @map("sent_at")
  conversationId  String?   @map("conversation_id")
  contactPhone    String?   @map("contact_phone")
  createdByUserId String    @map("created_by_user_id")

  // Phase 2 — CRM linkage + versioning. dealId is nullable: quote creation
  // still works standalone (today's UX, unchanged); the API auto-creates a
  // one-off Deal behind the scenes when none is given, so dealId always
  // ends up populated without forcing a deal-first flow in the wizard.
  dealId       String?   @map("deal_id")
  version      Int       @default(1)
  isPrimary    Boolean   @default(true) @map("is_primary")
  sentVia      String?   @default("whatsapp") @map("sent_via")
  acceptedAt   DateTime? @map("accepted_at")
  rejectedAt   DateTime? @map("rejected_at")
  // "SPLIT" (today's itemized-per-line-GST behavior, zero change) | "FLAT_18"
  // (compute path intentionally unimplemented — see docs/DATA_GAPS.md #16).
  gstMode      String    @default("SPLIT") @map("gst_mode")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  conversation Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  createdBy    User           @relation(fields: [createdByUserId], references: [id])
  deal         Deal?          @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealLineItems DealLineItem[]

  @@index([status])
  @@index([conversationId])
  @@index([contactPhone])
  @@index([createdAt])
  @@index([dealId, version])
  @@map("quotations")
}

// Centralized media library. Every file upload goes through here so we can
// list, audit, and de-dup. Existing template/message media URLs continue to
// work without a Media row — the library only shows what was uploaded via
// the new flows.
model Media {
  id               String   @id @default(uuid())
  url              String
  mimeType         String   @map("mime_type")
  fileName         String   @map("file_name")
  size             Int
  width            Int?
  height           Int?
  duration         Int? // seconds for audio/video
  // "image" | "video" | "audio" | "document" | "other" — denormalized from
  // mimeType for cheap filtering in the library UI.
  category         String   @default("other")
  uploadedByUserId String   @map("uploaded_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  uploadedBy User @relation(fields: [uploadedByUserId], references: [id])

  @@index([category])
  @@index([uploadedByUserId])
  @@map("media")
}

// Audit log for auto-reply rule firings. Every time a rule fires we
// record which rule + which contact + when so the dispatcher can honour
// per-contact cooldowns (don't spam the customer with the same greeting
// twice in 24 hours) and admin has visibility into what the bot sent.
model AutoReplyLog {
  id             String   @id @default(uuid())
  ruleId         String   @map("rule_id")
  conversationId String   @map("conversation_id")
  contactPhone   String   @map("contact_phone")
  triggeredBy    String?  @map("triggered_by")
  waMessageId    String?  @map("wa_message_id")
  firedAt        DateTime @default(now()) @map("fired_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([ruleId, contactPhone, firedAt])
  @@index([conversationId])
  @@map("auto_reply_logs")
}

// Chatbot state — a lightweight state machine per conversation. Drives
// the multi-turn flow (Phase 0 menu → branch → data collection → end).
// One row per conversation; deleted or ended after completion. 4-hour
// timeout after last update — next inbound restarts from Phase 0.
model ConversationFlow {
  id             String    @id @default(uuid())
  conversationId String    @unique @map("conversation_id")
  // "turnkey_new" | "turnkey_maintenance" | "consultation" | "product" | null (menu shown, path not picked yet)
  path           String?
  // Step identifier from the code-side step registry (e.g. "menu",
  // "p1a_name", "p1b_service", "p3_datetime", "done").
  currentStep    String    @map("current_step")
  // JSON of collected fields: {name, phone, location, landSize, sport,
  // maintenanceType, preferredDateTime, ...}. Nullable until first field
  // captured; overwritten on each step advance.
  collectedData  String    @default("{}") @map("collected_data")
  startedAt      DateTime  @default(now()) @map("started_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  endedAt        DateTime? @map("ended_at")
  // "completed" | "off_script" | "timeout" | null (still active)
  endReason      String?   @map("end_reason")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([currentStep])
  @@index([updatedAt])
  @@map("conversation_flows")
}

// Captured leads from the chatbot. One row per completed (or partially
// completed off-script) flow. Sales sees these in a daily data-sheet at
// /leads and moves them into the pipeline manually.
model BotLead {
  id                String    @id @default(uuid())
  conversationId    String    @map("conversation_id")
  contactPhone      String    @map("contact_phone")
  contactName       String?   @map("contact_name")
  // "turnkey_new" | "turnkey_maintenance" | "consultation" | "product"
  path              String
  location          String?
  // For turnkey_new: land size (ft). For turnkey_maintenance: turf size.
  sizeFt            Decimal?  @map("size_ft") @db.Decimal(10, 2)
  // For turnkey_new
  sport             String?
  // For turnkey_maintenance
  maintenanceType   String?   @map("maintenance_type")
  // For product
  productCategory   String?   @map("product_category")
  // For consultation — ISO datetime string of preferred callback slot
  preferredDateTime DateTime? @map("preferred_datetime")
  // "new" | "in_progress" | "contacted" | "converted" | "lost"
  status            String    @default("new")
  assignedToUserId  String?   @map("assigned_to_user_id")
  notes             String?
  // Set going forward whenever the chatbot creates a BotLead — mirrors it
  // into the general CRM Lead pipeline without touching this model's own
  // chatbot-specific fields. Nullable/optional — historical rows won't have it.
  leadId            String?   @map("lead_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([path])
  @@index([assignedToUserId])
  @@index([conversationId])
  @@map("bot_leads")
}

// Court layout designs — visual 2D editable canvas that exports a PNG sent
// to the customer over WhatsApp. The full editable layout (sports, plot,
// element positions/sizes/rotations/colors, annotations) is stored as JSON
// so sales can re-open the design, tweak it, and re-render. The same
// schema feeds a future 3D renderer without remodeling.
//
// Numbering: "FIT-CIM-YYYY-NNN" sequential per calendar year.
// Status flow: draft -> sent.
model CourtImage {
  id              String    @id @default(uuid())
  number          String    @unique
  customerName    String    @map("customer_name")
  // JSON snapshot of the CourtLayout — see src/lib/court-image/schema.ts.
  // Shape: { plot, sports, elements: [...], style }.
  layout          String
  // PNG exported from the canvas + uploaded to Vercel Blob.
  // Null until the user saves/sends; re-saved if they edit.
  // imageUrl is the "primary" — set to whichever format was sent first,
  // for inbox mirror compatibility. Format-specific URLs below track all
  // the variants the user generated so a single design can be re-sent as
  // 2D plan + 3D snapshot + 3D orbit video in any combination.
  imageUrl        String?   @map("image_url")
  image2dUrl      String?   @map("image_2d_url")
  image3dUrl      String?   @map("image_3d_url")
  video3dUrl      String?   @map("video_3d_url")
  caption         String?
  status          String    @default("draft")
  conversationId  String?   @map("conversation_id")
  contactPhone    String?   @map("contact_phone")
  createdByUserId String    @map("created_by_user_id")
  // Phase 2 — fulfills the spec's CourtDesign role in place, rather than
  // introducing a redundant model (CourtImage already IS the parametric
  // designer's output). Nullable, same pattern as Quotation.dealId.
  dealId          String?   @map("deal_id")
  sentAt          DateTime? @map("sent_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  createdBy    User          @relation(fields: [createdByUserId], references: [id])
  deal         Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([conversationId])
  @@index([contactPhone])
  @@index([createdAt])
  // dealId was added (comment above: "same pattern as Quotation.dealId")
  // but, unlike Quotation ([dealId, version]), never got its own index —
  // getRepDeals() (src/lib/analytics/repDeals.ts) filters court_images by
  // dealId IN (...) for every deal on a rep's roster; without this it's a
  // full-table scan of court_images on every call.
  @@index([dealId])
  @@map("court_images")
}

// Past Fitoverse builds. When a customer asks "what football turfs have
// you done?", sales pulls a sport-filtered slice of these into a
// catalogue PDF + hero photos and sends it on WhatsApp.
//
// `featured` controls inclusion in the catalogue PDF (so admin can curate
// which builds best represent the brand) without deleting older rows.
// `archived` hides from the default listing without breaking external
// references (the sport catalogue PDF that's already been sent to a
// customer keeps working even if the project is archived later).
model PortfolioProject {
  id               String    @id @default(uuid())
  customerName     String    @map("customer_name")
  location         String?
  sport            String
  completionDate   DateTime? @map("completion_date")
  plotLengthFt     Int?      @map("plot_length_ft")
  plotWidthFt      Int?      @map("plot_width_ft")
  surfaceType      String?   @map("surface_type")
  surfaceGrade     String?   @map("surface_grade")
  // Admin-only display field; never sent to customers. Used internally
  // for catalogue tier hints (entry / standard / premium).
  totalCostInr     Decimal?  @map("total_cost_inr") @db.Decimal(12, 2)
  shortDescription String?   @map("short_description")
  // JSON array of { url, caption?: string }. Hero photo is rendered
  // separately on the catalogue cover; gallery shows on the project
  // page + PDF "past projects" section.
  photos           String    @default("[]")
  heroPhotoUrl     String?   @map("hero_photo_url")
  videoUrl         String?   @map("video_url")
  // Free-form JSON for sport-specific specs (e.g. turf brand,
  // a-side preset, pitch length) — surfaces in the catalogue PDF.
  specs            String    @default("{}")
  // Comma-separated for simple search
  tags             String    @default("")
  featured         Boolean   @default(false)
  archived         Boolean   @default(false)
  createdByUserId  String    @map("created_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  createdBy User @relation(fields: [createdByUserId], references: [id])

  @@index([sport])
  @@index([featured])
  @@index([archived])
  @@map("portfolio_projects")
}

// ─────────────────────────────────────────────────────────────────────
//  Internal product catalogue (replaces the MVPv2 dependency).
//
//  Sales uploads floorings, materials, and sports equipment here. The
//  court designer + chatbot read from these tables instead of the
//  sibling MVPv2 web tool. TDS PDFs attach per sport (and optionally to
//  a specific product).
// ─────────────────────────────────────────────────────────────────────

model Product {
  id          String @id @default(uuid())
  name        String
  // "flooring" | "material" | "equipment"
  //   flooring  — turf / acrylic / PPE tile / PVC surfaces
  //   material  — infill, adhesives, sub-base consumables
  //   equipment — goal posts, nets, machines, shot clocks, etc.
  type        String
  description String @default("")
  // JSON array of sport keys this product applies to, e.g.
  // ["football","multisport"]. Court designer + chatbot filter by sport.
  sports      String @default("[]")
  // Optional sub-category within a type — flooring → "turf" / "acrylic"
  // / "ppe_tile" / "pvc"; equipment → "goal" / "net" / "machine".
  category    String?
  // Hero photo shown in listings. Gallery + video live in ProductMedia.
  heroImageUrl String? @map("hero_image_url")
  videoUrl     String? @map("video_url")
  // Free-form JSON specs { key: value } shown in the product detail +
  // combined PDF.
  specs        String  @default("{}")
  // Optional indicative price + unit for the combined PDF / quote line.
  priceInr     Decimal? @map("price_inr") @db.Decimal(12, 2)
  unit         String?
  // For flooring: the base work it sits on ("concrete" | "asphalt" |
  // null). Informational — surfaces in the design + PDF.
  baseWork     String?  @map("base_work")
  featured     Boolean  @default(false)
  archived     Boolean  @default(false)
  createdByUserId String @map("created_by_user_id")

  // Phase 2 additions. code is a short human ref (nullable — historical
  // products won't have one, admin can backfill via the products UI).
  // gstPercent is reporting/autofill metadata — the wizard's own per-line
  // gstPercent (RateSheetItem-driven) stays the actual compute source, see
  // docs/DECISIONS.md. currentRate/rateIsConfirmed separate "no rate set
  // yet" from "rate is genuinely zero" — never silently render as ₹0.
  code             String?          @unique
  productCategoryId String?         @map("product_category_id")
  defaultUnit      String?          @map("default_unit")
  gstPercent       Decimal?         @db.Decimal(5, 2) @map("gst_percent")
  currentRate      Decimal?         @db.Decimal(12, 2) @map("current_rate")
  rateIsConfirmed  Boolean          @default(false) @map("rate_is_confirmed")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdBy       User             @relation(fields: [createdByUserId], references: [id])
  productCategory ProductCategory? @relation(fields: [productCategoryId], references: [id])
  media           ProductMedia[]
  tdsFiles        TdsFile[]
  dealLineItems   DealLineItem[]
  rateHistory     ProductRateHistory[]

  @@index([type])
  @@index([featured])
  @@index([archived])
  @@map("products")
}

// Phase 2 — audit trail for Product.currentRate changes, so quotations can
// be re-costed and margin drift is visible over time. Quotations snapshot
// the rate at send time into DealLineItem.rate — never join live to
// Product.currentRate for a historical quote's numbers.
model ProductRateHistory {
  id            String   @id @default(uuid())
  productId     String   @map("product_id")
  rate          Decimal  @db.Decimal(12, 2)
  effectiveFrom DateTime @default(now()) @map("effective_from")
  setByUserId   String?  @map("set_by_user_id")
  createdAt     DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, effectiveFrom])
  @@map("product_rate_history")
}

model ProductMedia {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  url       String
  // "image" | "video"
  kind      String   @default("image")
  caption   String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_media")
}

model TdsFile {
  id               String   @id @default(uuid())
  sport            String
  name             String
  url              String
  // Optional link to a specific product (a TDS can be sport-level or
  // product-specific).
  productId        String?  @map("product_id")
  uploadedByUserId String?  @map("uploaded_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([sport])
  @@index([productId])
  @@map("tds_files")
}

// ─────────────────────────────────────────────────────────────────────────
// CRM (Phase 1) — see docs/DECISIONS.md for the reconciliation calls behind
// every naming/shape choice below (AccountContact vs the pre-existing
// Contact model, ...UserId suffix convention, Decimal-rupee money fields,
// nullable-everywhere migration safety, etc).
// ─────────────────────────────────────────────────────────────────────────

// Shared shape for every admin-editable taxonomy list (funnel stages, lead
// sources, customer profiles, ...). "Delete" always means isActive=false +
// deletedAt — never a hard delete — so history/analytics referencing an old
// row stay intact. colorHex renders via inline style, never a Tailwind class
// (see DECISIONS.md — Tailwind's JIT purger can't see dynamic class names).

model FunnelStage {
  id                 String    @id @default(uuid())
  name               String
  slug               String    @unique
  sortOrder          Int       @default(0) @map("sort_order")
  isActive           Boolean   @default(true) @map("is_active")
  colorHex           String?   @map("color_hex")
  // "active" | "won" | "lost"
  stageType          String    @map("stage_type")
  probabilityPercent Int?      @map("probability_percent")
  slaHours           Int?      @map("sla_hours")
  requiresLossReason Boolean   @default(false) @map("requires_loss_reason")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  deals        Deal[]
  stageHistoryFrom DealStageHistory[] @relation("StageHistoryFrom")
  stageHistoryTo   DealStageHistory[] @relation("StageHistoryTo")

  @@index([isActive, sortOrder])
  @@map("funnel_stages")
}

model LeadSource {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  colorHex  String?   @map("color_hex")
  // Optional grouping, e.g. "Paid Ads" as parent of google_ads/meta_ads/youtube_ads.
  parentId  String?   @map("parent_id")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  parent   LeadSource?  @relation("LeadSourceHierarchy", fields: [parentId], references: [id])
  children LeadSource[] @relation("LeadSourceHierarchy")
  leads    Lead[]
  deals    Deal[]
  adSpend  AdSpend[]

  @@index([isActive, sortOrder])
  @@map("lead_sources")
}

// Manual monthly ad spend per source, admin-entered (spec §11.3.G) — makes
// cost-per-lead/CAC/ROAS computable once Fitoverse starts supplying figures.
// No rows exist until then; sources.ts renders those columns empty rather
// than hiding them, per the spec's explicit instruction not to hide the gap.
model AdSpend {
  id           String   @id @default(uuid())
  leadSourceId String   @map("lead_source_id")
  // First day of the month this spend covers, e.g. 2026-07-01.
  month        DateTime
  amount       Decimal  @db.Decimal(12, 2)
  setByUserId  String   @map("set_by_user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  leadSource LeadSource @relation(fields: [leadSourceId], references: [id])

  @@unique([leadSourceId, month])
  @@map("ad_spend")
}

model CustomerProfile {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  colorHex  String?   @map("color_hex")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  accounts Account[]

  @@index([isActive, sortOrder])
  @@map("customer_profiles")
}

model CityTier {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  colorHex  String?   @map("color_hex")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  accounts Account[]
  deals    Deal[]

  @@index([isActive, sortOrder])
  @@map("city_tiers")
}

model LossReason {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  colorHex  String?   @map("color_hex")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  deals Deal[]

  @@index([isActive, sortOrder])
  @@map("loss_reasons")
}

model ActivityType {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  colorHex  String?   @map("color_hex")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  activities Activity[]
  reminders  Reminder[]

  @@index([isActive, sortOrder])
  @@map("activity_types")
}

// Phase 2 — top-level product grouping (spec §7.1). Distinct from the
// pre-existing free-text Product.category (sub-category within a type,
// e.g. "turf"/"acrylic") — this is the new admin-editable taxonomy layer.
model ProductCategory {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  colorHex  String?   @map("color_hex")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  products Product[]

  @@index([isActive, sortOrder])
  @@map("product_categories")
}

// Phase 4 — project-cost bands for analytics filtering (spec §11.2).
// Ships with a single "All" band; the real boundaries are data gap #2 in
// docs/DATA_GAPS.md — not guessed.
model ValueBand {
  id        String    @id @default(uuid())
  label     String
  minValue  Decimal?  @map("min_value") @db.Decimal(12, 2)
  maxValue  Decimal?  @map("max_value") @db.Decimal(12, 2)
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([isActive, sortOrder])
  @@map("value_bands")
}

// Phase 1 (analytics v2) — admin-entered revenue/deal-count goals a period's
// actuals are measured against. scopeId is the userId when scopeType=USER,
// null for a company-wide row (scopeType=COMPANY) — never both null and
// USER, enforced at the write layer (targets.ts), not the DB. periodStart is
// always the first day of the period (month/quarter/FY start) so the unique
// constraint below can't collide on two different in-period dates for the
// same scope.
model Target {
  id            String   @id @default(uuid())
  scopeType     String   @map("scope_type") // "USER" | "COMPANY"
  scopeId       String?  @map("scope_id") // userId when scopeType=USER, null for company-wide
  periodType    String   @map("period_type") // "MONTH" | "QUARTER" | "FY"
  periodStart   DateTime @map("period_start")
  targetRevenue Decimal  @map("target_revenue") @db.Decimal(12, 2)
  targetDeals   Int?     @map("target_deals")
  setByUserId   String   @map("set_by_user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  setByUser User @relation(fields: [setByUserId], references: [id])

  @@unique([scopeType, scopeId, periodType, periodStart])
  @@map("targets")
}

// The buying organisation — distinct from AccountContact (the human) and
// Lead (the raw enquiry). Anchor for repeat-customer analysis: when the same
// school buys a second court, it attaches to this same Account.
model Account {
  id                String    @id @default(uuid())
  name              String
  customerProfileId String?   @map("customer_profile_id")
  // "B2B" | "B2C" | "B2G"
  businessType      String?   @map("business_type")
  city              String?
  cityTierId        String?   @map("city_tier_id")
  ownerUserId       String?   @map("owner_user_id")
  parentAccountId   String?   @map("parent_account_id")
  gstin             String?
  notes             String?
  importBatchId     String?   @map("import_batch_id")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  customerProfile CustomerProfile? @relation(fields: [customerProfileId], references: [id])
  cityTier        CityTier?        @relation(fields: [cityTierId], references: [id])
  owner           User?            @relation("AccountOwner", fields: [ownerUserId], references: [id])
  parentAccount   Account?         @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  childAccounts   Account[]        @relation("AccountHierarchy")
  contacts        AccountContact[]
  deals           Deal[]
  activities      Activity[]
  importBatch     ImportBatch?     @relation("AccountImports", fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([city, customerProfileId])
  @@index([importBatchId])
  @@map("accounts")
}

// A person at an Account. Named AccountContact (not "Contact" per the spec)
// because "Contact" already exists as the unrelated broadcast/marketing
// contact list model — see DECISIONS.md.
model AccountContact {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  name      String
  phone     String?
  email     String?
  designation String?
  notes     String?
  fields    String   @default("{}") // JSON object of ad-hoc custom fields — same shape as Contact.fields
  isPrimary Boolean  @default(false) @map("is_primary")
  // Leads funnel stage — null = plain contact, "LEAD" = promoted lead. A lead
  // counts as "converted" once it has a Deal via dealsAsPrimary (derived, not
  // stored here).
  pipelineStage String? @map("pipeline_stage") // null = plain contact, "LEAD" = promoted lead
  importBatchId String? @map("import_batch_id")
  createdAt DateTime @default(now()) @map("created_at")
  // Soft delete, matching Account/Deal's own convention — a hard delete
  // would hit a bare FK RESTRICT the moment any Deal still points at this
  // contact as its primaryContactId (that relation has no onDelete set),
  // so anyone with an active deal could never actually be deleted. Every
  // read site filters deletedAt: null.
  deletedAt DateTime? @map("deleted_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  dealsAsPrimary Deal[] @relation("DealPrimaryContact")
  reminders Reminder[]
  activities Activity[]
  importBatch ImportBatch? @relation("AccountContactImports", fields: [importBatchId], references: [id], onDelete: SetNull)
  generalNotes AccountContactNote[]
  attachments AccountContactAttachment[]
  // The WhatsApp marketing Contact this was linked from, if any — the
  // other side of Contact.accountContactId.
  marketingContact Contact?

  @@index([accountId])
  @@index([importBatchId])
  @@map("account_contacts")
}

// A free-form running note log per contact — deliberately separate from
// Activity (which is structured: a type, a subject, duration, outcome).
// This is the plain scratchpad Zoho's own Notes tab is, not a logged
// touchpoint, so it's excluded from every analytics function on purpose —
// don't wire it into salesActivity.ts's notesWritten-style counts.
model AccountContactNote {
  id               String   @id @default(uuid())
  accountContactId String   @map("account_contact_id")
  authorUserId     String   @map("author_user_id")
  title            String?
  body             String
  createdAt        DateTime @default(now()) @map("created_at")

  accountContact AccountContact @relation(fields: [accountContactId], references: [id], onDelete: Cascade)
  author         User           @relation(fields: [authorUserId], references: [id])

  @@index([accountContactId, createdAt])
  @@map("account_contact_notes")
}

// Documents uploaded against a contact (ID proofs, signed agreements, site
// photos, etc.) — one place for everything tied to that person, visible to
// the owning sales rep and admin alike (same owner-or-admin scoping every
// other AccountContact-nested write already uses). Files live in the same
// public Vercel Blob store the rest of the app uses (uploadToBlob), not a
// separate storage mechanism.
model AccountContactAttachment {
  id               String   @id @default(uuid())
  accountContactId String   @map("account_contact_id")
  uploadedByUserId String   @map("uploaded_by_user_id")
  fileName         String   @map("file_name")
  fileUrl          String   @map("file_url")
  fileSize         Int      @map("file_size")
  mimeType         String   @map("mime_type")
  createdAt        DateTime @default(now()) @map("created_at")

  accountContact AccountContact @relation(fields: [accountContactId], references: [id], onDelete: Cascade)
  uploadedBy     User           @relation(fields: [uploadedByUserId], references: [id])

  @@index([accountContactId, createdAt])
  @@map("account_contact_attachments")
}

// A raw enquiry before it's qualified into a Deal. Kept thin — fast capture
// is the point. BotLead (chatbot-originated leads) stays separate and gets
// a nullable link here (leadId) so chatbot-specific fields aren't lost while
// every lead still shows up in this general CRM pipeline.
model Lead {
  id             String    @id @default(uuid())
  name           String
  phone          String
  email          String?
  city           String?
  rawEnquiryText String?   @map("raw_enquiry_text")
  leadSourceId   String?   @map("lead_source_id")
  sourceDetail   String?   @map("source_detail")
  ownerUserId    String?   @map("owner_user_id")
  // "NEW" | "CONTACTED" | "QUALIFIED" | "DISQUALIFIED"
  status         String    @default("NEW")
  convertedDealId String?  @unique @map("converted_deal_id")
  convertedAt    DateTime? @map("converted_at")
  importBatchId  String?   @map("import_batch_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  leadSource   LeadSource? @relation(fields: [leadSourceId], references: [id])
  owner        User?       @relation("LeadOwner", fields: [ownerUserId], references: [id])
  convertedDeal Deal?      @relation("LeadConvertedDeal", fields: [convertedDealId], references: [id])
  botLeads     BotLead[]
  activities   Activity[]
  importBatch  ImportBatch? @relation("LeadImports", fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([ownerUserId, createdAt])
  @@index([leadSourceId, createdAt])
  @@index([importBatchId])
  @@map("leads")
}

// The central sales object — one project opportunity at one site.
// Conversation -> Deal is 1-to-many (mirrors the existing Conversation ->
// Quotation / Conversation -> CourtImage pattern) since one WhatsApp thread
// can cover more than one site enquiry. transitionDeal() (src/lib/funnel/)
// is the only code path allowed to change currentStageId.
model Deal {
  id               String    @id @default(uuid())
  code             String    @unique
  title            String
  accountId        String    @map("account_id")
  primaryContactId String?   @map("primary_contact_id")
  ownerUserId      String?   @map("owner_user_id")
  officeId         String?   @map("office_id")
  currentStageId   String    @map("current_stage_id")
  leadSourceId     String?   @map("lead_source_id")
  sourceDetail     String?   @map("source_detail")
  conversationId   String?   @map("conversation_id")
  // "whatsapp" | "crm" — which side of the app created this deal. Always set
  // by the creating code path, never left to infer from conversationId at
  // read time (see docs/DECISIONS.md).
  dealChannel      String    @default("crm") @map("deal_channel")

  siteCity       String? @map("site_city")
  siteCityTierId String? @map("site_city_tier_id")
  siteState      String? @map("site_state")
  siteAddress    String? @map("site_address")

  estimatedValue Decimal? @map("estimated_value") @db.Decimal(12, 2)
  quotedValue    Decimal? @map("quoted_value") @db.Decimal(12, 2)
  wonValue       Decimal? @map("won_value") @db.Decimal(12, 2)

  // Post-won delivery tracking, so analytics/execution.ts can measure backlog
  // and delivery time — null = not yet started (or deal isn't WON). Nothing
  // sets these yet; that's DealDetailClient.tsx's job in this same phase.
  executionStatus     String?   @map("execution_status") // "IN_EXECUTION" | "COMPLETED"
  executionStartedAt  DateTime? @map("execution_started_at")
  deliveryCompletedAt DateTime? @map("delivery_completed_at")

  enquiryAt       DateTime  @default(now()) @map("enquiry_at")
  firstContactAt  DateTime? @map("first_contact_at")
  siteVisitAt     DateTime? @map("site_visit_at")
  sampleSentAt    DateTime? @map("sample_sent_at")
  firstQuotedAt   DateTime? @map("first_quoted_at")
  negotiationAt   DateTime? @map("negotiation_at")
  closedAt        DateTime? @map("closed_at")
  expectedCloseAt DateTime? @map("expected_close_at")

  // "WON" | "LOST" | "DROPPED" | null (still open)
  outcome        String?
  lossReasonId   String?   @map("loss_reason_id")
  // Free-text fallback — the pre-existing Conversation.lostReason is noisy
  // sales-rep free text; preserved verbatim here rather than force-mapped
  // into the LossReason taxonomy (see DECISIONS.md).
  lossReasonNote String?   @map("loss_reason_note")

  importBatchId String? @map("import_batch_id")

  // Manually-typed next step surfaced on the contact/deal page (Zoho-style
  // "next action" line) — free text plus its own due date, independent of the
  // structured Reminder task list.
  nextActionNote  String?   @map("next_action_note")
  nextActionDueAt DateTime? @map("next_action_due_at")

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  account        Account          @relation(fields: [accountId], references: [id])
  primaryContact AccountContact?  @relation("DealPrimaryContact", fields: [primaryContactId], references: [id])
  owner          User?            @relation("DealOwner", fields: [ownerUserId], references: [id])
  office         Office?          @relation(fields: [officeId], references: [id])
  currentStage   FunnelStage      @relation(fields: [currentStageId], references: [id])
  leadSource     LeadSource?      @relation(fields: [leadSourceId], references: [id])
  siteCityTier   CityTier?        @relation(fields: [siteCityTierId], references: [id])
  lossReason     LossReason?      @relation(fields: [lossReasonId], references: [id])
  conversation   Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  convertedFromLead Lead?         @relation("LeadConvertedDeal")
  stageHistory   DealStageHistory[]
  lineItems      DealLineItem[]
  quotations     Quotation[]
  courtImages    CourtImage[]
  activities     Activity[]
  reminders      Reminder[]
  importBatch    ImportBatch?     @relation("DealImports", fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([ownerUserId, currentStageId])
  @@index([siteCity, createdAt])
  @@index([currentStageId, expectedCloseAt])
  // Phase 6 — every Phase 4 analytics function filters deletedAt + a date
  // range (createdAt for "deals in this period", closedAt for cycle-time /
  // won-value stats), almost always alongside ownerUserId. Added once the
  // combined 8-screen smoke test measured ~9.5s against a tiny (18-deal)
  // dataset — see docs/DECISIONS.md.
  @@index([deletedAt, createdAt])
  @@index([deletedAt, outcome, closedAt])
  // Every sibling model with the same nullable conversationId FK
  // (Quotation, CourtImage) already indexes it — Deal never did, despite
  // 3 call sites filtering/updating by it (findOrCreateDealForConversation,
  // the deal-defaults lookup, and the conversation-reassignment sync added
  // 2026-07-16 — see docs/DECISIONS.md). Flagged by a performance audit,
  // not yet measured as an active slowdown, but additive/free to fix.
  @@index([conversationId])
  @@index([importBatchId])
  @@index([deletedAt, dealChannel])
  @@map("deals")
}

// Append-only. Source of truth for funnel + timing analytics — never
// update or delete rows here. changedByUserId is nullable (unlike the
// pre-existing PipelineStageHistory.changedByUserId) so a future
// system-driven transition doesn't need a synthetic user.
model DealStageHistory {
  id                         String    @id @default(uuid())
  dealId                     String    @map("deal_id")
  fromStageId                String?   @map("from_stage_id")
  toStageId                  String    @map("to_stage_id")
  changedByUserId            String?   @map("changed_by_user_id")
  changedAt                  DateTime  @default(now()) @map("changed_at")
  durationInFromStageSeconds Int?      @map("duration_in_from_stage_seconds")
  note                       String?

  deal      Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStage FunnelStage? @relation("StageHistoryFrom", fields: [fromStageId], references: [id])
  toStage   FunnelStage  @relation("StageHistoryTo", fields: [toStageId], references: [id])
  changedBy User?        @relation(fields: [changedByUserId], references: [id])

  @@index([dealId, changedAt])
  @@index([toStageId, changedAt])
  // stageVelocity() (src/lib/analytics/timelines.ts) filters changedAt range
  // + fromStageId not null, then groups by fromStageId — the toStageId
  // sibling index above doesn't serve that (leading column mismatch), and
  // there was no fromStageId index at all. Mirrors the toStageId index above.
  @@index([fromStageId, changedAt])
  @@map("deal_stage_history")
}

// Product-level detail — drives product-movement analytics. Populated from
// a quotation (quotationId set) OR captured as pre-quote interest
// (isEnquiryOnly=true, quotationId null) via a Deal's "Interested in"
// picker — this split is what makes enquiry-vs-sold-by-product answerable.
// Coexists with Quotation.lineItems (JSON) — that stays the PDF-rendering
// source of truth; this is a parallel, denormalized analytics projection.
model DealLineItem {
  id            String   @id @default(uuid())
  dealId        String   @map("deal_id")
  quotationId   String?  @map("quotation_id")
  productId     String?  @map("product_id")
  sportId       String?  @map("sport_id")
  // Free-text label for enquiry-only rows with no product chosen yet.
  label         String?
  quantity      Decimal  @db.Decimal(12, 2)
  unit          String?
  rate          Decimal? @db.Decimal(12, 2)
  amount        Decimal? @db.Decimal(12, 2)
  isEnquiryOnly Boolean  @default(false) @map("is_enquiry_only")
  createdAt     DateTime @default(now()) @map("created_at")

  deal      Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  quotation Quotation? @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  product   Product?   @relation(fields: [productId], references: [id])
  sport     Sport?     @relation(fields: [sportId], references: [id])

  @@index([productId, dealId])
  @@index([dealId])
  @@map("deal_line_items")
}

// Real Sport table — replaces the two independently-duplicated hardcoded
// TS unions in rates.ts (SUPPORTED_SPORTS) and products/store.ts
// (SPORT_KEYS). Those stay as the form-validation source of truth for now
// (touching the PDF/rate-sheet pipeline that keys off them is out of
// scope here) and are seeded to match this table exactly.
model Sport {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  dealLineItems DealLineItem[]

  @@map("sports")
}

// Unified touchpoint log — consolidates what today is built ad hoc by
// merging separate queries against ConversationNote/PipelineStageHistory/
// Reminder/Message in src/app/api/team/analytics/route.ts.
model Activity {
  id                String    @id @default(uuid())
  dealId            String?   @map("deal_id")
  leadId            String?   @map("lead_id")
  accountId         String?   @map("account_id")
  accountContactId  String?   @map("account_contact_id")
  activityTypeId    String    @map("activity_type_id")
  ownerUserId       String    @map("owner_user_id")
  subject           String
  notes             String?
  occurredAt        DateTime  @map("occurred_at")
  durationMins      Int?      @map("duration_mins")
  outcome           String?
  createdAt         DateTime  @default(now()) @map("created_at")

  deal           Deal?            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lead           Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  account        Account?         @relation(fields: [accountId], references: [id], onDelete: SetNull)
  accountContact AccountContact?  @relation(fields: [accountContactId], references: [id], onDelete: SetNull)
  activityType   ActivityType     @relation(fields: [activityTypeId], references: [id])
  owner          User             @relation("ActivityOwner", fields: [ownerUserId], references: [id])

  @@index([ownerUserId, occurredAt])
  @@index([dealId, occurredAt])
  @@index([leadId, occurredAt])
  @@index([accountId, occurredAt])
  @@index([accountContactId, occurredAt])
  @@map("activities")
}

// Tracks each CRM import (Contacts/Companies/Leads/Deals) for audit + undo.
// Rows created BY this batch are stamped with importBatchId on the target
// table (never on rows the import merely updated) so "undo" is always a
// safe deleteMany({ importBatchId }) — it can never delete a pre-existing
// row the import happened to touch.
model ImportBatch {
  id              String   @id @default(uuid())
  importedByUserId String  @map("imported_by_user_id")
  target          String   // "CONTACTS" | "COMPANIES" | "LEADS" | "DEALS"
  fileName        String   @map("file_name")
  rowCount        Int      @map("row_count")
  successCount    Int      @map("success_count")
  errorCount      Int      @map("error_count")
  createdAt       DateTime @default(now()) @map("created_at")

  importedBy User @relation(fields: [importedByUserId], references: [id])
  accounts        Account[]        @relation("AccountImports")
  accountContacts AccountContact[] @relation("AccountContactImports")
  leads           Lead[]           @relation("LeadImports")
  deals           Deal[]           @relation("DealImports")

  @@index([importedByUserId, createdAt])
  @@map("import_batches")
}
