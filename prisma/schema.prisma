// Prisma schema for WhatsApp Tool
// Run: npx prisma db push (or migrate dev)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite did not support native enums, so we use String fields.
// Allowed values (validated at the API layer via Zod):
//   role: "admin" | "sales"
//   user.approvalStatus: "pending" | "approved" | "rejected"
//   template.status: "draft" | "pending_admin" | "submitted" | "approved" | "rejected" | "paused"
//   broadcast.status: "draft" | "running" | "completed" | "failed"
//   conversation.status: "open" | "closed"
//   message.direction: "inbound" | "outbound"
//   message.type: "text" | "template" | "image" | "document" | "video" | "audio"
//   message.status: "queued" | "sent" | "delivered" | "read" | "failed"

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  name            String
  role            String
  approvalStatus  String    @default("pending") @map("approval_status")
  rejectionReason String?   @map("rejection_reason")
  isActive        Boolean   @default(true) @map("is_active")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  draftedTemplates     Template[]             @relation("DraftedTemplates")
  approvedTemplates    Template[]             @relation("ApprovedTemplates")
  assignedConvos       Conversation[]         @relation("AssignedConversations")
  sentMessages         Message[]
  broadcasts           Broadcast[]
  authoredNotes        ConversationNote[]
  reminders            Reminder[]
  pipelineStageChanges PipelineStageHistory[]
  uploadedMedia        Media[]

  @@map("users")
}

model Template {
  id                String    @id @default(uuid())
  name              String
  language          String
  category          String
  header            String?
  body              String
  footer            String?
  buttons           String?
  status            String    @default("draft")
  metaTemplateId    String?   @unique @map("meta_template_id")
  rejectionReason   String?   @map("rejection_reason")
  draftedByUserId   String    @map("drafted_by_user_id")
  approvedByUserId  String?   @map("approved_by_user_id")
  submittedAt       DateTime? @map("submitted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  // Soft delete — when set, template is hidden from default list views
  // and excluded from the Broadcasts template picker. The Meta-side
  // template is NOT deleted; admin can restore from the "Show deleted"
  // filter on the Templates page.
  deletedAt         DateTime? @map("deleted_at")

  draftedBy  User        @relation("DraftedTemplates", fields: [draftedByUserId], references: [id])
  approvedBy User?       @relation("ApprovedTemplates", fields: [approvedByUserId], references: [id])
  broadcasts Broadcast[]
  messages   Message[]

  @@index([status])
  @@index([deletedAt])
  @@map("templates")
}

model Conversation {
  id                  String    @id @default(uuid())
  contactPhone        String    @unique @map("contact_phone")
  contactName         String?   @map("contact_name")
  assignedToUserId    String?   @map("assigned_to_user_id")
  originBroadcastId   String?   @map("origin_broadcast_id")
  status              String    @default("open")
  lastInboundAt       DateTime? @map("last_inbound_at")
  lastOutboundAt      DateTime? @map("last_outbound_at")
  unreadCount         Int       @default(0) @map("unread_count")
  createdAt           DateTime  @default(now()) @map("created_at")

  // Pipeline / lead funnel fields. All nullable to keep migration zero-risk for
  // existing rows. pipelineStage default "new" applies to fresh inserts only;
  // existing rows get null and surface in the "Unsorted" column until a sales
  // user drags them to a stage.
  pipelineStage    String?   @default("new") @map("pipeline_stage")
  stageChangedAt   DateTime? @map("stage_changed_at")
  dealValue        Decimal?  @db.Decimal(12, 2) @map("deal_value")
  expectedCloseAt  DateTime? @map("expected_close_at")
  lostReason       String?   @map("lost_reason")

  assignedTo      User?                 @relation("AssignedConversations", fields: [assignedToUserId], references: [id])
  originBroadcast Broadcast?            @relation(fields: [originBroadcastId], references: [id])
  messages        Message[]
  notes           ConversationNote[]
  reminders       Reminder[]
  stageHistory    PipelineStageHistory[]
  labels          ConversationToLabel[]

  @@index([assignedToUserId])
  @@index([status])
  @@index([pipelineStage])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  direction      String
  type           String
  body           String?
  mediaUrl       String?  @map("media_url")
  // Media metadata captured at upload/download time. Lets the UI render the
  // right preview (image/video/audio/document) without round-tripping to
  // Meta or refetching the blob. mediaMimeType drives the chooser; the
  // rest are display niceties.
  mediaMimeType  String?  @map("media_mime_type")
  mediaFileName  String?  @map("media_file_name")
  mediaSize      Int?     @map("media_size")
  mediaWidth     Int?     @map("media_width")
  mediaHeight    Int?     @map("media_height")
  mediaDuration  Int?     @map("media_duration") // seconds for audio/video
  waMessageId    String?  @unique @map("wa_message_id")
  templateId     String?  @map("template_id")
  status         String   @default("queued")
  errorCode      String?  @map("error_code")
  errorMessage   String?  @map("error_message")
  sentByUserId   String?  @map("sent_by_user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  template     Template?    @relation(fields: [templateId], references: [id])
  sentBy       User?        @relation(fields: [sentByUserId], references: [id])

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Contact {
  id            String   @id @default(uuid())
  phone         String   @unique @map("phone_e164")
  name          String?
  allowCampaign Boolean  @default(true) @map("allow_campaign") // consent gate — false = never broadcast
  fields        String   @default("{}") // JSON object of extra columns (location, category, etc.)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tags ContactTag[]

  @@map("contacts")
}

model Broadcast {
  id               String    @id @default(uuid())
  name             String
  sourceType       String    @default("file") @map("source_type") // "file" | "sheet" | "contacts"
  sheetId          String?   @map("sheet_id")
  sheetRange       String?   @map("sheet_range")
  fileData         String?   @map("file_data")
  templateId       String    @map("template_id")
  variableMapping  String    @map("variable_mapping")
  // status: "draft" | "scheduled" | "running" | "completed" | "failed"
  status           String    @default("draft")
  total            Int       @default(0)
  sent             Int       @default(0)
  delivered        Int       @default(0)
  read             Int       @default(0)
  failed           Int       @default(0)
  createdByUserId  String    @map("created_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  // When set, broadcast is held in "scheduled" status until the launch cron
  // (or a safety on-load check) flips it to "running". Hobby cron = up to 1hr
  // delay; we surface this in the UI.
  scheduledAt      DateTime? @map("scheduled_at")
  launchedAt       DateTime? @map("launched_at")
  completedAt      DateTime? @map("completed_at")
  // Pause control. pauseRequestedAt is set when the user clicks Pause; the
  // sender loop checks this between batches and writes pausedAt + flips
  // status to "paused" once it's actually safe to stop. Resume clears both.
  pauseRequestedAt DateTime? @map("pause_requested_at")
  pausedAt         DateTime? @map("paused_at")

  template      Template             @relation(fields: [templateId], references: [id])
  createdBy     User                 @relation(fields: [createdByUserId], references: [id])
  recipients    BroadcastRecipient[]
  conversations Conversation[]

  @@index([createdByUserId])
  @@index([status])
  @@index([scheduledAt])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id           String    @id @default(uuid())
  broadcastId  String    @map("broadcast_id")
  phoneE164    String    @map("phone_e164")
  name         String?
  variables    String
  waMessageId  String?   @unique @map("wa_message_id")
  status       String    @default("queued")
  errorCode    String?   @map("error_code")
  errorMessage String?   @map("error_message")
  sentAt       DateTime? @map("sent_at")
  deliveredAt  DateTime? @map("delivered_at")
  readAt       DateTime? @map("read_at")

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, phoneE164])
  @@index([waMessageId])
  @@map("broadcast_recipients")
}

model OptOut {
  phoneE164   String   @id @map("phone_e164")
  optedOutAt  DateTime @default(now()) @map("opted_out_at")
  reason      String

  @@map("opt_outs")
}

// Key-value config storage. Holds the long-lived Meta access token
// and its expiry (seconds since epoch) for the auto-refresh cycle.
// Keys: "meta_access_token", "meta_token_expires_at",
//       "pipeline_stages" (JSON array of stage configs)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// Free-text notes attached to a conversation, visible to all users who can
// access that conversation. Pinned notes float to the top of the panel.
model ConversationNote {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  authorUserId   String    @map("author_user_id")
  body           String
  pinned         Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  editedAt       DateTime? @map("edited_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorUserId], references: [id])

  @@index([conversationId, createdAt])
  @@map("conversation_notes")
}

// Per-user follow-up reminders. May be linked to a conversation (most common)
// or standalone. The cron worker fires notifiedAt when notifying; UI also
// performs an on-load safety check for overdue reminders.
model Reminder {
  id             String    @id @default(uuid())
  conversationId String?   @map("conversation_id")
  ownerUserId    String    @map("owner_user_id")
  message        String
  dueAt          DateTime  @map("due_at")
  completedAt    DateTime? @map("completed_at")
  notifiedAt     DateTime? @map("notified_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  owner        User          @relation(fields: [ownerUserId], references: [id])

  @@index([ownerUserId, dueAt])
  @@index([dueAt, completedAt])
  @@map("reminders")
}

// Append-only audit log of pipeline stage changes. Powers the "days in stage"
// metric and cycle-time analytics.
model PipelineStageHistory {
  id              String   @id @default(uuid())
  conversationId  String   @map("conversation_id")
  fromStage       String?  @map("from_stage")
  toStage         String   @map("to_stage")
  changedByUserId String   @map("changed_by_user_id")
  changedAt       DateTime @default(now()) @map("changed_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  changedBy    User         @relation(fields: [changedByUserId], references: [id])

  @@index([conversationId, changedAt])
  @@map("pipeline_stage_history")
}

// Colored, named tags applied to contacts. Tag names are globally unique;
// color is a tailwind palette token (slate/blue/amber/...) — see lib/
// pipeline.ts STAGE_COLOR_CLASSES for the recognised set.
model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("slate")
  createdAt DateTime @default(now()) @map("created_at")

  contacts ContactTag[]

  @@map("tags")
}

model ContactTag {
  contactId String   @map("contact_id")
  tagId     String   @map("tag_id")
  taggedAt  DateTime @default(now()) @map("tagged_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
  @@map("contact_tags")
}

// Operational state labels applied to conversations (distinct from
// pipeline stages which model the sales funnel). Examples: "Needs follow-up",
// "Waiting customer", "Action required".
model ConversationLabel {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("slate")
  createdAt DateTime @default(now()) @map("created_at")

  conversations ConversationToLabel[]

  @@map("conversation_labels")
}

model ConversationToLabel {
  conversationId String   @map("conversation_id")
  labelId        String   @map("label_id")
  labeledAt      DateTime @default(now()) @map("labeled_at")

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  label        ConversationLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([conversationId, labelId])
  @@index([labelId])
  @@map("conversation_to_labels")
}

// Centralized media library. Every file upload goes through here so we can
// list, audit, and de-dup. Existing template/message media URLs continue to
// work without a Media row — the library only shows what was uploaded via
// the new flows.
model Media {
  id               String   @id @default(uuid())
  url              String
  mimeType         String   @map("mime_type")
  fileName         String   @map("file_name")
  size             Int
  width            Int?
  height           Int?
  duration         Int? // seconds for audio/video
  // "image" | "video" | "audio" | "document" | "other" — denormalized from
  // mimeType for cheap filtering in the library UI.
  category         String   @default("other")
  uploadedByUserId String   @map("uploaded_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")

  uploadedBy User @relation(fields: [uploadedByUserId], references: [id])

  @@index([category])
  @@index([uploadedByUserId])
  @@map("media")
}
